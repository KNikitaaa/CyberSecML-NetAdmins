# Copy this file to .env and fill only your own credentials.
# Never commit .env, .Renviron, or files under inst/extdata.

DEEPSEEK_API_KEY=
OPENAI_API_KEY=
LLM_API_KEY=
GITHUB_PAT=

# Default provider is DeepSeek. For other OpenAI-compatible providers, set
# LLM_PROVIDER=openai_compatible, LLM_BASE_URL, LLM_MODEL, and LLM_API_KEY.
LLM_PROVIDER=deepseek
LLM_MODEL=
LLM_BASE_URL=
LLM_CALL_MODE=tools
LLM_RESPONSE_FORMAT=
OTM_FRESH_DISCOVERY_LLM_SLOTS=5
LLM_MAX_RECORDS=

# Docker uses /app/inst/extdata. For a local R run you can leave this unset
# and the package will use inst/extdata inside the project.
OFFENSIVETOOLMAPPER_DATA_DIR=/app/inst/extdata
OTM_MITRE_MAPPING_MIN_CONFIDENCE=0.7

OTM_MCP_TRANSPORT=http
OTM_MCP_PORT=3000
