# OffensiveToolMapper — шаблон переменных окружения
# Скопируй файл в .env и впиши свои значения:
#   PowerShell: Copy-Item .env.example .env
#   Bash:       cp .env.example .env
#
# .env не коммитится в git. Docker Compose подхватывает его автоматически.

# =============================================================================
# 1. LLM-провайдер — выбор нейросети для пайплайна
# =============================================================================
#
# Поддерживаемые провайдеры:
#   openai    — ChatGPT (OpenAI)         → OPENAI_API_KEY
#   anthropic — Claude (Anthropic)       → ANTHROPIC_API_KEY
#   deepseek  — DeepSeek                 → DEEPSEEK_API_KEY
#   xai       — Grok (xAI)              → XAI_API_KEY
#   groq      — Groq (LLaMA / Mixtral)  → GROQ_API_KEY
#   mistral   — Mistral AI              → MISTRAL_API_KEY
#   ollama    — локальный Ollama        → ключ не нужен
#
# Для запуска пайплайна с конкретным провайдером задай LLM_PROVIDER и
# соответствующий API-ключ. Пример для Claude:
#   LLM_PROVIDER=anthropic
#   LLM_MODEL=claude-sonnet-4-6
#   ANTHROPIC_API_KEY=sk-ant-...

LLM_PROVIDER=openai

# Модель. Оставь пустым — будет выбрана модель по умолчанию для провайдера:
#   openai    → gpt-4.1-mini
#   anthropic → claude-sonnet-4-6
#   deepseek  → deepseek-chat
#   xai       → grok-3-mini
#   groq      → llama-3.3-70b-versatile
#   mistral   → mistral-small-latest
#   ollama    → qwen3:8b
LLM_MODEL=

# Кастомный OpenAI-compatible endpoint (необязательно).
# Оставь пустым — используется стандартный URL провайдера.
# Пример для локального LM Studio: LLM_BASE_URL=http://localhost:1234/v1
LLM_BASE_URL=

# Ограничение числа записей за один запуск (необязательно).
# Удобно для тестового запуска: LLM_MAX_RECORDS=20
LLM_MAX_RECORDS=

# -----------------------------------------------------------------------------
# API-ключи провайдеров (заполни только нужный)
# -----------------------------------------------------------------------------

# OpenAI (ChatGPT)
OPENAI_API_KEY=
# Необязательно: organization/project ID для мультиаккаунтных организаций
OPENAI_ORG_ID=
OPENAI_PROJECT_ID=

# Anthropic (Claude)
ANTHROPIC_API_KEY=

# DeepSeek
DEEPSEEK_API_KEY=

# xAI (Grok)
XAI_API_KEY=

# Groq
GROQ_API_KEY=

# Mistral AI
MISTRAL_API_KEY=

# Ollama — локальный сервер, ключ не нужен.
# Поменяй LLM_BASE_URL если Ollama запущена не на localhost:11434.
# OLLAMA_API_KEY=  # Не нужен, можно не заполнять

# =============================================================================
# 2. Сбор данных с GitHub
# =============================================================================

# Токен GitHub. Без него сбор сильно ограничен rate-limit'ом.
GITHUB_PAT=

# Режим сбора: incremental (только новое) или snapshot (полный пересбор).
OTM_COLLECT_MODE=incremental

# Настройки GitHub-поиска. Уменьши для быстрого теста.
OTM_GITHUB_MIN_STARS=10
OTM_GITHUB_MAX_RESULTS=100
OTM_GITHUB_MAX_SEARCH_REQUESTS=60

# =============================================================================
# 3. Дополнительные источники данных (необязательно)
# =============================================================================

# --- RSS-ленты ---------------------------------------------------------------
# По умолчанию подключены: Exploit-DB, The Hacker News, BleepingComputer.
# Чтобы заменить список — укажи свои URL через точку с запятой:
# OTM_RSS_FEEDS=https://www.exploit-db.com/rss.xml;https://example.com/feed.xml
# Чтобы отключить RSS полностью:
# OTM_RSS_FEEDS=disabled
OTM_RSS_FEEDS=

# --- PacketStorm -------------------------------------------------------------
# PacketStorm поддерживает два способа сбора:
#
# 1) API-доступ (нужен ключ): задай PACKETSTORM_API_SECRET
#    PACKETSTORM_API_SECRET=ваш-ключ
#
# 2) Ручные URL (без ключа): укажи адреса страниц через точку с запятой:
#    PACKETSTORM_URLS=https://packetstormsecurity.com/files/...;https://...
#
# Оставь пустым — PacketStorm отключён.
PACKETSTORM_API_SECRET=
PACKETSTORM_URLS=

# =============================================================================
# 4. Docker / Shiny / MCP — обычно менять не нужно
# =============================================================================

OTM_MCP_TRANSPORT=http
OTM_MCP_PORT=3000

# Директория с данными. Для локального R оставь пустым (= inst/extdata).
# Docker Compose сам выставляет /app/inst/extdata внутри контейнеров.
OFFENSIVETOOLMAPPER_DATA_DIR=
